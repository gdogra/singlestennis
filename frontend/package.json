{
  "name": "singlestennis-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "cd .. && husky install frontend/.husky",
    "dev": "cross-env NODE_ENV=development npm run validate-env && vite",
    "build": "cross-env NODE_ENV=production npm run validate-env && vite build",
    "preview": "vite preview",
    "validate-env": "node scripts/validate-env.cjs",
    "generate-env-example": "node scripts/generate-env-example.cjs",
    "lint": "eslint . --ext .js,.jsx",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@react-oauth/google": "^0.12.1",
    "axios": "^1.6.8",
    "dotenv": "^16.4.7",
    "framer-motion": "^12.6.3",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^0.487.0",
    "moment": "^2.30.1",
    "react": "^18.2.0",
    "react-big-calendar": "^1.18.0",
    "react-datetime-picker": "^6.0.1",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "react-toastify": "^11.0.5",
    "recharts": "^2.15.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "eslint": "^8.56.0",
    "husky": "^8.0.3",
    "postcss": "^8.5.3",
    "prettier": "^3.2.5",
    "tailwindcss": "^3.4.17",
    "vite": "^4.5.2"
  }
}
